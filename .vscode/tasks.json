{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OpenAPI: 依存関係インストール",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder:contract}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      }
    },
    {
      "label": "OpenAPI: スキーマ検証",
      "type": "shell",
      "command": "npm",
      "args": ["run", "validate"],
      "options": {
        "cwd": "${workspaceFolder:contract}"
      },
      "dependsOn": "OpenAPI: 依存関係インストール",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "OpenAPI: スキーマ検証（詳細）",
      "type": "shell",
      "command": "npm",
      "args": ["run", "validate:verbose"],
      "options": {
        "cwd": "${workspaceFolder:contract}"
      },
      "dependsOn": "OpenAPI: 依存関係インストール",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      }
    },
    {
      "label": "OpenAPI: スキーマをバンドル（YAML）",
      "type": "shell",
      "command": "npm",
      "args": ["run", "bundle"],
      "options": {
        "cwd": "${workspaceFolder:contract}"
      },
      "dependsOn": "OpenAPI: スキーマ検証",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      }
    },
    {
      "label": "OpenAPI: スキーマをバンドル（JSON）",
      "type": "shell",
      "command": "npm",
      "args": ["run", "bundle:json"],
      "options": {
        "cwd": "${workspaceFolder:contract}"
      },
      "dependsOn": "OpenAPI: スキーマ検証",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      }
    },
    {
      "label": "OpenAPI: 検証 → バンドル（YAML + JSON）",
      "type": "shell",
      "command": "npm",
      "args": ["run", "validate:then:bundle"],
      "options": {
        "cwd": "${workspaceFolder:contract}"
      },
      "dependsOn": "OpenAPI: 依存関係インストール",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      }
    },
    {
      "label": "制御: フォーカスをスキーマ検証パネルに",
      "type": "shell",
      "command": "echo '✓ 検証パネルにフォーカスしました'",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "swagger"
      },
      "runOptions": {
        "instanceLimit": 1
      },
      "isBackground": true
    }
  ]
}
