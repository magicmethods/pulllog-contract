{
  "name": "pulllog-api-contract",
  "version": "1.0.0",
  "description": "PullLog API Contract - OpenAPI 3.0 Specification",
  "scripts": {
    "validate": "swagger-cli validate api-schema.yaml",
    "validate:verbose": "swagger-cli validate api-schema.yaml --debug",
    "bundle": "swagger-cli bundle api-schema.yaml --type yaml --outfile api-schema.bundle.yaml",
    "bundle:json": "swagger-cli bundle api-schema.yaml --type json --outfile api-schema.bundle.json",
    "validate:then:bundle": "npm run validate && npm run bundle && npm run bundle:json",
    "drift:frontend": "node scripts/detect-api-drift.mjs --source frontend --format md",
    "drift:backend": "node scripts/detect-api-drift.mjs --source backend --format md",
    "drift:all": "node scripts/detect-api-drift.mjs --source all --format md",
    "drift:json": "node scripts/detect-api-drift.mjs --source all --format json",
    "drift:ci": "node scripts/detect-api-drift.mjs --source all --format md --fail-on-drift"
  },
  "devDependencies": {
    "swagger-cli": "^4.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
